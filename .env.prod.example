# Production reference
# The application does not auto-load .env.prod.
# In production, inject these variables through the platform
# or copy the final values into .env before starting the app.

NODE_ENV=production
PORT=3001

# Main database
# Use the real PostgreSQL host and credentials of the production environment.
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=your-postgres-user
DB_PASSWORD=change-me
DB_DATABASE=api_db

# Auth
# Use a long random secret generated specifically for production.
JWT_SECRET=pedir-discord-chave-deploy

# Frontend
# Set the real frontend origin when CORS is restricted.
FRONTEND_URL=https://your-frontend.example.com
