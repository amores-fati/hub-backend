# E2E / integration tests
# Copy this file to .env.e2e when running automated integration tests locally.
# Never reuse the same database name from .env or .env.test here.

NODE_ENV=test
PORT=3001

DB_HOST=127.0.0.1
DB_PORT=5436
DB_USERNAME=root
DB_PASSWORD=secret
DB_DATABASE=api_db_e2e

JWT_SECRET=change-me-for-e2e
