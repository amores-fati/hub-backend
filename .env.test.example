# Test / manual QA database
# Copy this file to .env.test when running manual test-db tooling against api_db_test.
# Never reuse the same database name from .env here.

NODE_ENV=test
PORT=3001

# Test database
# The bootstrap refuses to run if DB_DATABASE matches the main database.
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USERNAME=root
DB_PASSWORD=secret
DB_DATABASE=api_db_test

# Explicit test target used by the integration bootstrap.
DB_TEST_HOST=127.0.0.1
DB_TEST_PORT=5433
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=secret
DB_TEST_DATABASE=api_db_test

# Auth
JWT_SECRET=change-me-for-tests
