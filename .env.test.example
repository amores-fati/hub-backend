# Test / manual QA database
# Copy this file to .env.test when running manual test-db tooling against api_db_test.
# Never reuse the same database name from .env here.

NODE_ENV=test
PORT=3001

# Test database
# The bootstrap refuses to run if DB_DATABASE matches the main database.
DB_HOST=127.0.0.1
DB_PORT=55433
DB_USERNAME=root
DB_PASSWORD=secret
DB_DATABASE=api_db_test

# Explicit test target used by the integration bootstrap.
DB_TEST_HOST=127.0.0.1
DB_TEST_PORT=55433
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=secret
DB_TEST_DATABASE=api_db_test

# Auth
JWT_SECRET=10dddd4cd802ed65b345898daa47f8de4d8abb1d7c24991167916e32de923e92

# Password reset email
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login
SMTP_PASSWORD=your-smtp-key
EMAIL_FROM=your-verified-sender@example.com
FRONTEND_URL=http://localhost:3000
RESET_PASSWORD_TOKEN_EXPIRATION_MINUTES=30
