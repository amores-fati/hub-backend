# Development / local runtime
# Copy this file to .env when running the API locally or via docker compose.
NODE_ENV=development
PORT=3001

# Main database
# These values are ideal when the API runs on the host machine
# and PostgreSQL is exposed by docker compose on localhost:5434.
# Inside the api container, docker compose overrides DB_HOST/DB_PORT
# to use the postgres service on port 5432.
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=root
DB_PASSWORD=secret
DB_DATABASE=api_db

# Test database
# Persistent database for manual testing and exploratory API use.
# `docker compose up` prepares this database with migrations and seed.
# Never point these values to the same database used by DB_DATABASE.
DB_TEST_HOST=localhost
DB_TEST_PORT=5433
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=secret
DB_TEST_DATABASE=api_db_test

# Automated E2E database lives in .env.e2e / .env.e2e.example

# Auth
JWT_SECRET=10dddd4cd802ed65b345898daa47f8de4d8abb1d7c24991167916e32de923e92

# Frontend
# Optional today. Keep it here to avoid future drift when CORS origin
# becomes configurable instead of open.
FRONTEND_URL=http://localhost:3000
