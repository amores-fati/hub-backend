{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "test/integration/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/mocks/uuid.ts",
    "^src/(.*)$": "<rootDir>/../src/$1"
  }
}
