{
  "info": {
    "name": "Hub Backend — Courses",
    "_postman_id": "hub-courses-collection",
    "description": "Collection para testar os endpoints de cursos implementados na task feat/listagemDeCurso.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (obter token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  console.log('Token salvo automaticamente.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fatilab.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Autentica e salva o accessToken automaticamente na variável da collection."
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "GET /courses — listar cursos (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"]
            },
            "description": "Rota pública. Retorna todos os cursos ordenados por data de criação (mais recentes primeiro). Não requer autenticação."
          }
        },
        {
          "name": "POST /courses — criar curso (requer token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Desenvolvimento Web Full Stack\",\n  \"banner\": \"https://fatilab.com/banners/web.jpg\",\n  \"description\": \"Curso completo de desenvolvimento web com React e Node.js.\",\n  \"courseLoad\": \"120h\",\n  \"startDate\": \"2025-02-01T00:00:00.000Z\",\n  \"endDate\": \"2025-06-30T00:00:00.000Z\",\n  \"startRegistrations\": \"2025-01-01T00:00:00.000Z\",\n  \"endRegistrations\": \"2025-01-28T00:00:00.000Z\",\n  \"linkAccess\": \"https://fatilab.com/cursos/web\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"]
            },
            "description": "Rota protegida. Execute o Login primeiro para o token ser preenchido automaticamente."
          }
        },
        {
          "name": "POST /courses — sem token (deve retornar 401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste sem autenticacao\",\n  \"banner\": \"https://fatilab.com/banners/teste.jpg\",\n  \"courseLoad\": \"10h\",\n  \"startDate\": \"2025-02-01T00:00:00.000Z\",\n  \"endDate\": \"2025-06-30T00:00:00.000Z\",\n  \"startRegistrations\": \"2025-01-01T00:00:00.000Z\",\n  \"endRegistrations\": \"2025-01-28T00:00:00.000Z\",\n  \"linkAccess\": \"https://fatilab.com/cursos/teste\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"]
            },
            "description": "Valida que POST sem token retorna 401 Unauthorized."
          }
        }
      ]
    }
  ]
}
